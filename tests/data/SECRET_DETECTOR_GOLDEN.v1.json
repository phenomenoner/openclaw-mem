{
  "schema": "openclaw-mem.secret-detector-golden.v1",
  "version": 1,
  "cases": [
    {
      "id": "openai_sk_proj_token",
      "class": "high_risk",
      "sample": "sk-proj-AAAAAAAAAAAAAAAAAAAAAAAA",
      "mem_engine": {
        "detectorAnchor": "sk-proj-",
        "redactionAnchor": "sk-proj-[REDACTED]"
      },
      "plugin": {
        "redactionAnchor": "sk-proj-[REDACTED]"
      },
      "episodic": {
        "expectSecretLike": true,
        "expectGuardBlock": true,
        "leakNeedles": [
          "AAAAAAAA",
          "sk-proj-AAAA"
        ]
      }
    },
    {
      "id": "github_pat_token",
      "class": "high_risk",
      "sample": "github_pat_BBBBBBBBBBBBBBBBBBBBBBBB",
      "mem_engine": {
        "detectorAnchor": "github_pat_",
        "redactionAnchor": "[GITHUB_TOKEN_REDACTED]"
      },
      "plugin": {
        "redactionAnchor": "[GITHUB_TOKEN_REDACTED]"
      },
      "episodic": {
        "expectSecretLike": true,
        "expectGuardBlock": true,
        "leakNeedles": [
          "BBBBBBBB",
          "github_pat_BBBB"
        ]
      }
    },
    {
      "id": "aws_secret_assignment",
      "class": "high_risk",
      "sample": "aws_secret_access_key=CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC",
      "mem_engine": {
        "detectorAnchor": "aws[_-]?secret[_-]?access[_-]?key",
        "redactionAnchor": "aws_secret_access_key=[REDACTED]"
      },
      "plugin": {
        "redactionAnchor": "aws_secret_access_key=[REDACTED]"
      },
      "episodic": {
        "expectSecretLike": true,
        "expectGuardBlock": true,
        "leakNeedles": [
          "CCCCCCCC",
          "aws_secret_access_key=CCCC"
        ]
      }
    },
    {
      "id": "authorization_bearer_header",
      "class": "high_risk",
      "sample": "Authorization: Bearer DDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDD",
      "mem_engine": {
        "detectorAnchor": "Authorization:\\s*Bearer",
        "redactionAnchor": "Authorization: Bearer [REDACTED]"
      },
      "plugin": {
        "redactionAnchor": "Authorization: Bearer [REDACTED]"
      },
      "episodic": {
        "expectSecretLike": true,
        "expectGuardBlock": true,
        "leakNeedles": [
          "DDDDDDDD",
          "Bearer DDDD"
        ]
      }
    },
    {
      "id": "benign_bearer_docs_text",
      "class": "benign",
      "sample": "Use bearer tokens for OAuth flows; keep token storage in vault.",
      "episodic": {
        "expectSecretLike": false,
        "expectGuardBlock": false,
        "leakNeedles": []
      }
    },
    {
      "id": "benign_aws_env_docs_text",
      "class": "benign",
      "sample": "Set aws_secret_access_key from environment variables.",
      "episodic": {
        "expectSecretLike": false,
        "expectGuardBlock": false,
        "leakNeedles": []
      }
    }
  ],
  "receipt_expectations": {
    "memEngineAutoCapture": {
      "expectAggregateOnly": true,
      "forbidFields": [
        "text:"
      ]
    },
    "episodicGuard": {
      "expectErrorContains": "secret-like content"
    }
  }
}
